# -------------------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# -------------------------------------------------------

# --- HuggingFace Inference API ---
# Get your token from: https://huggingface.co/settings/tokens
# The token must have "Inference Providers" or "read" permission.
HF_TOKEN=hf_your_token_here
# Embedding model (must support feature-extraction on HF Inference API)
# Default: BAAI/bge-small-en-v1.5  (384-dim, good HF router compatibility)
# Other options: thenlper/gte-small
EMBED_MODEL=BAAI/bge-small-en-v1.5
# Embedding vector dimension for EMBED_MODEL (bge-small-en-v1.5 = 384)
EMBED_DIM=384

# Chat/LLM model (must support text-generation / chat_completion on HF Inference API)
# Default: mistralai/Mistral-7B-Instruct-v0.3
# Other options: meta-llama/Meta-Llama-3-8B-Instruct, HuggingFaceH4/zephyr-7b-beta
CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct:novita

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# In production, set this to your actual domain(s).
# Example: https://myapp.com,https://www.myapp.com
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,null

# --- Cleanup ---
# Auto-delete conversations not updated in this many days. Set to 0 to disable.
CONVERSATION_RETENTION_DAYS=10

CHAT_PROVIDER="hf-inference"

# --- MongoDB ---
# MongoDB connection string for your RAG vector store. Ensure it is an Atlas cluster if you are using Vector Search.
# Example: mongodb+srv://username:password@cluster0.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/?retryWrites=true&w=majority
# Database and collection used by the app for chunk + embedding storage
MONGODB_DB_NAME=your_database_name
MONGODB_COLLECTION=your_collection_name
# Name of the Atlas vector search index. This must match the index created in Atlas.
MONGODB_INDEX_NAME=vector_index

# --- RAG Retrieval ---
# Number of chunks fetched from the knowledge base per query.
# Higher = better recall but more context sent to the LLM. Default: 6
RAG_TOP_K=6
